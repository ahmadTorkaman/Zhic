# Database
DATABASE_URI=postgresql://postgres:password@localhost:5432/zhic

# Payload
PAYLOAD_SECRET=change-me-32-chars-minimum

# Abr Arvan S3-compatible Object Storage
# Leave S3_ACCESS_KEY empty for local dev (falls back to local disk storage)
S3_BUCKET=zhic-media
S3_REGION=ir-thr-at1
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Public URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Extra origins (comma-separated) allowed to use the admin panel / authenticated
# API, beyond NEXT_PUBLIC_SERVER_URL. Payload's CORS+CSRF checks reject requests
# from any other origin with 403 ("you can't perform this action"). Set this when
# the admin is served on a different origin than serverURL — e.g. the storefront
# is :3000 (serverURL) but the API+admin are reached directly on :3001.
PAYLOAD_ADMIN_ORIGINS=http://localhost:3001

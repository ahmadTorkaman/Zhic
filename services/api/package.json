{
  "name": "@zhic/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "generate:types": "payload generate:types",
    "seed": "tsx src/seed.ts",
    "seed:rooms": "tsx scripts/seed-rooms.mts",
    "migrate": "tsx scripts/migrate.mts migrate",
    "migrate:create": "tsx scripts/migrate.mts migrate:create",
    "migrate:status": "tsx scripts/migrate.mts migrate:status",
    "migrate:down": "tsx scripts/migrate.mts migrate:down",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@next/env": "^16.2.6",
    "@payloadcms/db-postgres": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/storage-s3": "^3.83.0",
    "@types/pg": "^8.20.0",
    "@zhic/db": "workspace:*",
    "@zhic/types": "workspace:*",
    "graphql": "^16.9.0",
    "next": "16.2.2",
    "payload": "^3.83.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@zhic/config": "workspace:*",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "xlsx": "^0.18.5"
  }
}

{
  "extends": "@zhic/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@payload-config": ["./src/payload.config.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*",
    ".next/dev/types/**/*"
  ],
  "exclude": ["node_modules", "src/seed.ts", "scripts", "src/migrations"]
}

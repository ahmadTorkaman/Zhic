{
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "api": {
      "root": "services/api",
      "framework": "nextjs"
    }
  },
  "rewrites": [
    {
      "source": "/api/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "api"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}

# ── Environment ────────────────────────────────────────────────
# Set to "staging" or "production". Drives Caddy basic-auth, retention,
# public vs gated.
ZHIC_ENV=staging

# Primary public domain. For staging, this is "staging.zhicwood.com".
# For production, "zhicwood.com".
ZHIC_DOMAIN=staging.zhicwood.com

# Email address used by Caddy for Let's Encrypt notifications.
ZHIC_ACME_EMAIL=newton.ahmadreza@gmail.com

# ── Basic auth for staging only ────────────────────────────────
# Leave blank in production. For staging, bcrypt hash of a password.
# Generate: `caddy hash-password --plaintext "your-password"`
# Then set username + hash here.
ZHIC_STAGING_USER=zhic
ZHIC_STAGING_PASS_HASH=

# ── Postgres ───────────────────────────────────────────────────
POSTGRES_USER=zhic
POSTGRES_PASSWORD=                            # generate: `openssl rand -hex 24`
POSTGRES_DB=zhic
# What the app connects to (same box, Docker):
DATABASE_URI=postgresql://zhic:${POSTGRES_PASSWORD}@127.0.0.1:5432/zhic

# ── Payload ────────────────────────────────────────────────────
PAYLOAD_SECRET=                               # generate: `openssl rand -hex 32`
NEXT_PUBLIC_SERVER_URL=https://staging.zhicwood.com

# ── Abr Arvan S3 (Payload media) ───────────────────────────────
# Leave S3_ACCESS_KEY empty in staging → falls back to local disk.
S3_BUCKET=zhic-media
S3_REGION=ir-thr-at1
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── SMS.ir (inquiry form) ──────────────────────────────────────
# Leave blank in staging → messages logged to stdout only, not sent.
SMS_IR_API_KEY=
SMS_IR_LINE_NUMBER=
SMS_IR_TEMPLATE_ID=

# ── Plausible (optional, self-hosted analytics) ────────────────
# Only needed if you `docker compose --profile analytics up`.
PLAUSIBLE_SECRET_KEY_BASE=                    # generate: `openssl rand -hex 64`
PLAUSIBLE_BASE_URL=https://analytics.zhicwood.com

# ── Gitea (optional, production-side git server) ───────────────
# Only needed if you `docker compose --profile git up`.
GITEA_ROOT_URL=https://git.zhicwood.com
